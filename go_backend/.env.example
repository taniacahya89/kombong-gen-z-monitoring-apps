# Konfigurasi Environment - Kombong GenZ Backend
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke version control

# ===== SERVER =====
APP_PORT=3000
APP_ENV=development

# ===== DATABASE POSTGRESQL =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=ganti_dengan_password_anda
DB_NAME=kombong_genz
DB_SSLMODE=disable

# ===== MQTT BROKER =====
# Untuk lokal: gunakan Mosquitto (mqtt://localhost:1883)
# Untuk cloud: gunakan HiveMQ (hivemq.cloud) atau EMQX
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=kombong_genz_server
MQTT_USERNAME=
MQTT_PASSWORD=

# ===== JWT =====
# Ganti dengan string random yang panjang dan aman di production
JWT_SECRET=GANTI_DENGAN_SECRET_YANG_SANGAT_AMAN_DAN_PANJANG_DI_PRODUCTION
# Durasi kedaluwarsa token JWT dalam jam (default: 24)
JWT_EXPIRATION_HOURS=24
